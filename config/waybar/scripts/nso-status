#!/usr/bin/env bash
set -u

json() {
	local text="${1:-}"
	local tooltip="${2:-}"
	local class="${3:-normal}"

	jq -cn --arg text "$text" --arg tooltip "$tooltip" --arg class "$class" \
		'{text: $text, tooltip: $tooltip, class: $class}'
}

read_cpu() {
	awk '/^cpu / {
		idle = $5 + $6
		total = 0
		for (i = 2; i <= NF; i++) total += $i
		printf "%d %d\n", idle, total
	}' /proc/stat
}

set -- $(read_cpu)
idle_a="${1:-0}"
total_a="${2:-0}"
sleep 0.08
set -- $(read_cpu)
idle_b="${1:-0}"
total_b="${2:-0}"

idle_delta=$((idle_b - idle_a))
total_delta=$((total_b - total_a))
cpu=0
if [ "$total_delta" -gt 0 ]; then
	cpu=$((100 * (total_delta - idle_delta) / total_delta))
fi

mem="$(awk '
	/^MemTotal:/ { total = $2 }
	/^MemAvailable:/ { available = $2 }
	END {
		if (total > 0) printf "%d", ((total - available) * 100) / total
		else printf "0"
	}
' /proc/meminfo)"

uptime_seconds="$(awk '{ printf "%d", $1 }' /proc/uptime)"
uptime_hours=$((uptime_seconds / 3600))
uptime_minutes=$(((uptime_seconds % 3600) / 60))
hour_raw="$(date +%H)"
hour=$((10#$hour_raw))

class="normal"
mode="Ame READY"
text="Ame OK"

if [ "$cpu" -ge 90 ] || [ "$mem" -ge 90 ]; then
	class="critical"
	mode="Stress critical"
	text="Ame STRESS"
elif [ "$cpu" -ge 75 ] || [ "$mem" -ge 75 ]; then
	class="warning"
	mode="Load rising"
	text="Ame BUSY"
elif [ "$hour" -ge 22 ] || [ "$hour" -lt 5 ]; then
	class="streaming"
	mode="Night stream"
	text="KAngel LIVE"
elif [ "$uptime_hours" -ge 8 ]; then
	class="warning"
	mode="Long session"
	text="Ame TIRED"
fi

tooltip="NSO desktop status
Mode: $mode
CPU: $cpu%
RAM: $mem%
Screen time: ${uptime_hours}h ${uptime_minutes}m"

json "$text" "$tooltip" "$class"
